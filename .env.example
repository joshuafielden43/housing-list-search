# Production secrets live in ~/.hermes/.env (Hermes injects env for run_daily.sh / cron).
# Repo .env is optional — only for local manual runs without Hermes.
# cp .env.example .env

# Optional: Needs Review webhook (Hermes, n8n, …)
# HLS_NEEDS_REVIEW_WEBHOOK=https://example.com/hooks/needs-review

# Optional: Vikunja reverification tasks (project #9)
# HLS_VIKUNJA_URL=https://vikunja.example
# HLS_VIKUNJA_TOKEN=
# HLS_VIKUNJA_PROJECT_ID=9

# Optional: parallel target workers (default 3)
# HLS_MAX_TARGET_WORKERS=3

# OCR tier (marker-pdf) — multi-GB models; NOT for daily --run (ADR-0005 / #1088–#1089).
# Daily/cron: keep OCR dark (run_daily.sh forces this).
HLS_DISABLE_MARKER_PDF=1
# Opt-in only on a dedicated OCR host/job (also needs requirements-ocr.txt):
# HLS_ENABLE_MARKER_PDF=1
# HLS_DISABLE_MARKER_PDF=0